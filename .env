# LinkedIn Credentials
LINKEDIN_EMAIL=cue.ai.team@gmail.com
LINKEDIN_PASSWORD=Zyzz@1234567890

# Claude Mode — choose how the bot talks to Claude
# cli = uses the `claude` CLI tool (needs: npm install -g @anthropic-ai/claude-code + claude login)
# web = opens claude.ai in a browser tab (needs an active claude.ai account)
CLAUDE_MODE=cli

# Anthropic API Key — only needed if you ever switch back to CLAUDE_MODE=api
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Automation Config
WEEKLY_CONNECTION_LIMIT=5
HEADLESS=false
SLOW_MO=50

# CUE AI Product Context (used for AI prompts)
PRODUCT_NAME=CUE AI
PRODUCT_DESCRIPTION=A stealthy, always-on-top Electron overlay that listens to your system audio, transcribes speech in real time, and injects interview prompts directly into AI chat interfaces (ChatGPT, Claude, Gemini, DeepSeek).
FOUNDER_NAME=Raghu
FOUNDER_ROLE=Founder

# ─── Target Audience ────────────────────────────────────────────────────────

# LinkedIn search keywords — what the connect task searches for
TARGET_KEYWORDS=software engineer job search,developer interview preparation,open to work software engineer,SDE job hunting India,fresher software engineer,campus placement engineer,coding bootcamp graduate,junior developer job switch,software engineer 1-2 years experience,actively interviewing developer

# PRIMARY audience — people who actually buy
# Software engineers and developers actively interviewing at product companies, startups,
# or FAANG-equivalent roles in India. Failed interviews before, in an active job search,
# or planning a role switch in the next 1–3 months. Age 21–30. Tier 1/2 engineering
# college graduates. Know AI tools exist but haven't found one that works in the actual
# interview moment.
ICP_PRIMARY=Software engineers aged 21–30 in India who are actively interviewing or job hunting, have 0–3 years of experience, and have failed interview rounds not due to lack of knowledge but due to pressure and articulation problems

# SECONDARY audience — people who share and recommend
# Final year CS/IT students at NITs, IIITs, tier 2 colleges going through campus
# placements. Bootcamp students at Masai School, Newton School, Scaler, GUVI who are
# job hunting after their program. Price-sensitive — ₹200/hr resonates precisely
# because they can't afford $50/month tools.
ICP_SECONDARY=Final year CS/IT students at NITs/IIITs/tier-2 colleges and bootcamp graduates (Masai, Newton, Scaler, GUVI) actively job hunting, price-sensitive, for whom ₹200/hr is the key value unlock

# TERTIARY audience — amplifiers (don't buy, but recommend at scale)
# Career coaches and placement officers who work directly with job seekers. One
# placement officer endorsing Cue is worth more than a month of LinkedIn posts.
ICP_TERTIARY=Career coaches and college placement officers who recommend tools to hundreds of job-seeking students — they amplify reach without being direct buyers

# NOT the audience — instruct Claude to score these low
ICP_EXCLUDE=Experienced professionals with 5+ years passively open to opportunities, HR professionals, recruiters, non-tech job seekers, people not in engineering or technical roles

# The single clearest picture of the core user (used in AI prompts for tone/relevance)
ICP_CORE_USER=A 23-year-old software engineer with 1–2 years of experience who has failed 2–3 interview rounds at companies they were qualified for. They know it wasn't a knowledge problem — it was pressure and articulation. They are willing to pay ₹200 to make sure it doesn't happen again in their next session.

# Cron Schedule (default: every Monday at 9am)
CRON_SCHEDULE=0 9 * * 1

# Added by stabilization pass
DASHBOARD_PASSWORD=admin123
